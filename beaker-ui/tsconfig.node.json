{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "skipLibCheck": true,
    "verbatimModuleSyntax": false,
    "preserveSymlinks": true,
    "paths": {
      "vite": ["./node_modules/vite"]
    }
  },
  "include": [
    "vite.config.ts"
  ]
}
