{
  "name": "@jataware/beaker-vue",
  "version": "2.0.1",
  "description": "Beaker Notebook Vue component library",
  "declaration": true,
  "scripts": {
    "prebuild": "npm run type-check",
    "build": "run-s clean build-lib",
    "build-lib": "vite build --config vite.config.lib.ts && vue-tsc -p tsconfig.node.json",
    "postbuild-lib": "chmod +x ./dist/builder/extractRoutes.cjs",
    "test:unit": "vitest",
    "type-check": "vue-tsc --build --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "clean": "rimraf dist/*"
  },
  "bin": {
    "extract-routes": "./dist/builder/extractRoutes.cjs"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "./dist",
    "./src",
    "./tsconfig.renderers.json",
    "./vendor"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    },
    "./builder": {
      "types": "./dist/builder/build.d.ts",
      "default": "./dist/builder/build.mjs"
    },
    "./builder/build": {
      "types": "./dist/builder/build.d.ts",
      "default": "./dist/builder/build.mjs"
    },
    "./tsconfig.renderers.json": "./tsconfig.renderers.json"
  },
  "repository": {
    "url": "git+https://github.com/jataware/beaker-notebook.git"
  },
  "bundleDependencies": [
    "xlsx"
  ],
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@jataware/beaker-client": "^2.0.1",
    "@jupyterlab/coreutils": "^6.5.7",
    "@jupyterlab/mathjax-extension": "^4.5.7",
    "@jupyterlab/rendermime": "^4.5.7",
    "@plutojl/lang-julia": "^0.12.2",
    "@primevue/icons": "^4.5.5",
    "@primevue/themes": "^4.5.4",
    "@vue/language-core": "^3.3.3",
    "ansi-html-community": "^0.0.8",
    "buffer": "^6.0.3",
    "codemirror": "^6.0.2",
    "codemirror-lang-r": "^0.1.1",
    "content-disposition": "^2.0.0",
    "cookie": "^1.1.1",
    "cytoscape": "^3.33.3",
    "escape-html": "^1.0.3",
    "filesize": "^11.0.17",
    "hash-sum": "^2.0.0",
    "json5": "^2.2.3",
    "katex": "^0.16.46",
    "lodash": "^4.18.1",
    "marked": "^18.0.3",
    "panel": "^6.2.0",
    "path-browserify": "^1.0.1",
    "pdfjs-dist": "^5.7.284",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "scroll-into-view-if-needed": "^3.1.0",
    "uuid": "^14.0.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vue": "^3.5.34",
    "vue-codemirror": "^6.1.1",
    "vue-json-pretty": "^2.6.0",
    "vue-router": "^5.0.7",
    "xlsx": "file:vendor/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@tsconfig/node22": "^22.0.5",
    "@types/content-disposition": "^0.5.9",
    "@types/cookie": "^1.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/eslint-plugin": "^1.6.17",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "~10.9.1",
    "glob": "^13.0.6",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "loader-utils": "^3.3.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.3",
    "rimraf": "^6.1.3",
    "sass-embedded": "^1.99.0",
    "typescript": "~6.0.3",
    "vite": "^7.3.3",
    "vite-node": "^6.0.0",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vite-plugin-dts": "^5.0.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.9"
  },
  "peerDependencies": {
    "primevue": "^4.3.4"
  }
}
